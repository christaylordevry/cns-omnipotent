{
  "patterns": [
    {
      "id": "openai_proj_key",
      "regex": "sk-proj-[A-Za-z0-9_-]{20,}"
    },
    {
      "id": "openai_legacy_key",
      "regex": "sk-[A-Za-z0-9]{20,}"
    },
    {
      "id": "aws_access_key_id",
      "regex": "AKIA[0-9A-Z]{16}"
    },
    {
      "id": "github_pat_classic",
      "regex": "ghp_[A-Za-z0-9]{36}"
    },
    {
      "id": "slack_bot_token",
      "regex": "xoxb-[0-9]{10,13}-[0-9]{10,13}-[A-Za-z0-9]{24,}"
    }
  ]
}
