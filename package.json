{
  "name": "cns",
  "version": "0.0.0",
  "private": true,
  "description": "CNS Phase 1: vault contract, constitution mirror, Vault IO (scaffold grows in later stories)",
  "type": "module",
  "main": "./dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test:gate-failures": "node scripts/assert-verify-failure-modes.mjs",
    "test:node": "node --test tests/*.test.mjs",
    "test:vitest": "vitest run --config vitest.config.ts",
    "test": "npm run -s test:node && npm run -s test:vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.15",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
