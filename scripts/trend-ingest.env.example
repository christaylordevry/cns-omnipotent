# Trend ingest cron environment (~/.hermes/trend-ingest.env)
# Copy: cp scripts/trend-ingest.env.example ~/.hermes/trend-ingest.env && chmod 600 ~/.hermes/trend-ingest.env
# Never commit the live file — credentials stay on the operator machine only (NFR-S1).

# Convex HTTP push (same deployment as dashboard-sync)
CONVEX_URL=""
CONVEX_DEPLOY_KEY=""
# If deploy key contains |, wrap the value in double quotes in this file.

# Reddit (PRAW) — https://www.reddit.com/prefs/apps (script app)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="cns-trend-ingest/1.0 by YOUR_REDDIT_USERNAME"

# NewsAPI — https://newsapi.org/register (free tier ~100 req/day; see operator guide §16.5)
NEWSAPI_API_KEY=""

# Product Hunt — https://www.producthunt.com/v2/oauth/applications (developer token)
# Alias PRODUCTHUNT_API_TOKEN may appear in operator docs; code reads PRODUCTHUNT_API_KEY only.
# PRODUCTHUNT_API_KEY=""

# Morning digest Product Hunt tuning (Story 67-5) — optional; defaults shown
# MORNING_DIGEST_PRODUCTHUNT_ENABLED=1
# MORNING_DIGEST_PRODUCTHUNT_MAX_LAUNCHES=5

# Morning digest NewsAPI tuning (Story 64-6) — optional; defaults shown
# MORNING_DIGEST_NEWSAPI_WINDOW_HOURS=48
# MORNING_DIGEST_NEWSAPI_MAX_HEADLINES=5
# MORNING_DIGEST_NEWSAPI_PAGE_SIZE=20
# MORNING_DIGEST_NEWSAPI_ENABLED=1
# MORNING_DIGEST_NEWSAPI_QUERY=""

# Morning digest arXiv preprints (Story 64-7) — optional; defaults shown
# Public RSS — no API key. When categories unset, defaults to cs.AI,cs.LG,stat.ML
# MORNING_DIGEST_ARXIV_CATEGORIES=cs.AI,cs.LG,stat.ML
# MORNING_DIGEST_ARXIV_MAX_PER_CATEGORY=3
# MORNING_DIGEST_ARXIV_ENABLED=1
# Set MORNING_DIGEST_ARXIV_USE_DEFAULTS=0 to require explicit categories (empty → error)

# Analytics soak JSONL (Story 45-7) — optional override for audit-trend-analytics-soak.py
# Default: ~/.hermes/logs/trend-analytics.log (same path Convex runAnalyticsPass uses when unset)
# Set here for local tooling, or in Convex dashboard env for deployed Node actions.
# TREND_ANALYTICS_LOG="$HOME/.hermes/logs/trend-analytics.log"
