# Trend ingest cron environment (~/.hermes/trend-ingest.env)
# Copy: cp scripts/trend-ingest.env.example ~/.hermes/trend-ingest.env && chmod 600 ~/.hermes/trend-ingest.env
# Never commit the live file — credentials stay on the operator machine only (NFR-S1).

# Convex HTTP push (same deployment as dashboard-sync)
CONVEX_URL=""
CONVEX_DEPLOY_KEY=""
# If deploy key contains |, wrap the value in double quotes in this file.

# Reddit (PRAW) — https://www.reddit.com/prefs/apps (script app)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="cns-trend-ingest/1.0 by YOUR_REDDIT_USERNAME"

# NewsAPI — https://newsapi.org/register (free tier ~100 req/day; see operator guide §16.5)
NEWSAPI_API_KEY=""

# Analytics soak JSONL (Story 45-7) — optional override for audit-trend-analytics-soak.py
# Default: ~/.hermes/logs/trend-analytics.log (same path Convex runAnalyticsPass uses when unset)
# Set here for local tooling, or in Convex dashboard env for deployed Node actions.
# TREND_ANALYTICS_LOG="$HOME/.hermes/logs/trend-analytics.log"
