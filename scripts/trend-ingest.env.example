# Trend ingest cron environment (~/.hermes/trend-ingest.env)
# Copy: cp scripts/trend-ingest.env.example ~/.hermes/trend-ingest.env && chmod 600 ~/.hermes/trend-ingest.env
# Never commit the live file — credentials stay on the operator machine only (NFR-S1).

# Convex HTTP push (same deployment as dashboard-sync)
CONVEX_URL=""
CONVEX_DEPLOY_KEY=""
# If deploy key contains |, wrap the value in double quotes in this file.

# Reddit (PRAW) — Epic 44 trend-ingest only; morning-digest Source 8 uses public JSON (no credentials)
# https://www.reddit.com/prefs/apps (script app)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="cns-trend-ingest/1.0 by YOUR_REDDIT_USERNAME"

# NewsAPI — https://newsapi.org/register (free tier ~100 req/day; see operator guide §16.5)
NEWSAPI_API_KEY=""

# Product Hunt — https://www.producthunt.com/v2/oauth/applications (developer token)
# Alias PRODUCTHUNT_API_TOKEN may appear in operator docs; code reads PRODUCTHUNT_API_KEY only.
# PRODUCTHUNT_API_KEY=""

# Morning digest Product Hunt tuning (Story 67-5) — optional; defaults shown
# MORNING_DIGEST_PRODUCTHUNT_ENABLED=1
# MORNING_DIGEST_PRODUCTHUNT_MAX_LAUNCHES=5

# Morning digest X/Twitter session cookies (Story 68-6, health check Story 68-7)
# Required for live X: browser session cookies — NOT X Developer Portal bearer tokens.
# How to obtain: logged-in x.com → DevTools → Application → Cookies → copy auth_token → X_AUTH_TOKEN, ct0 → X_CT0
# See Operator Guide §15.11.1 for full rotation runbook.
# WSL: manual paste only — no @steipete/sweet-cookie / browser cookie reads.
# Rotation trigger: digest shows (source unavailable: X session invalid) OR health check exits non-zero:
#   node scripts/hermes-skill-examples/morning-digest/scripts/fetch-x-signals.mjs --check
#   bash scripts/session-close/hermes-run-x-check.sh
# X_AUTH_TOKEN=""
# X_CT0=""
# MORNING_DIGEST_X_ACCOUNTS=karpathy,sama,ylecun,emollick,simonw
# MORNING_DIGEST_X_SEARCH_QUERIES=
# MORNING_DIGEST_X_MAX_TWEETS=20
# MORNING_DIGEST_X_LOOKBACK_HOURS=24
# MORNING_DIGEST_X_ENABLED=1
# Deprecated / ignored by CNS (cookie GraphQL only — no official API v2):
# X_BEARER_TOKEN=""

# Morning digest Bluesky tuning (Story 68-5) — optional; public feeds only (no app password in v1)
# Comma-separated public handles; when unset, defaults to 8 AI/tech accounts (karpathy.bsky.social, simonwillison.net, etc.)
# MORNING_DIGEST_BSKY_ACTORS=karpathy.bsky.social,simonwillison.net,dannypostma.bsky.social,swyx.io,sama.bsky.social,ylecun.bsky.social,emollick.bsky.social,GaryMarcus.bsky.social
# MORNING_DIGEST_BSKY_ENABLED=1
# MORNING_DIGEST_BSKY_MAX_POSTS=25
# MORNING_DIGEST_BSKY_LOOKBACK_HOURS=24
# MORNING_DIGEST_BSKY_APPVIEW_HOST=https://api.bsky.app

# Morning digest NewsAPI tuning (Story 64-6) — optional; defaults shown
# MORNING_DIGEST_NEWSAPI_WINDOW_HOURS=48
# MORNING_DIGEST_NEWSAPI_MAX_HEADLINES=5
# MORNING_DIGEST_NEWSAPI_PAGE_SIZE=20
# MORNING_DIGEST_NEWSAPI_ENABLED=1
# MORNING_DIGEST_NEWSAPI_QUERY=""

# Morning digest arXiv preprints (Story 64-7) — optional; defaults shown
# Public RSS — no API key. When categories unset, defaults to cs.AI,cs.LG,stat.ML
# MORNING_DIGEST_ARXIV_CATEGORIES=cs.AI,cs.LG,stat.ML
# MORNING_DIGEST_ARXIV_MAX_PER_CATEGORY=3
# MORNING_DIGEST_ARXIV_ENABLED=1
# Set MORNING_DIGEST_ARXIV_USE_DEFAULTS=0 to require explicit categories (empty → error)

# Epic 72 morning-digest source tuning (ScrapeCreators + Polymarket + Threads)
# Copy values to ~/.hermes/trend-ingest.env — reference only; no secrets here.

# SCRAPECREATORS_API_KEY=""   # https://scrapecreators.com — shared by TikTok, Instagram, Pinterest, Threads (72-3/72-5/72-7)

# TikTok — Source 14 (Story 72-3)
# MORNING_DIGEST_TIKTOK_HASHTAGS=aiagents,claudeai,chatgpt,mcp
# MORNING_DIGEST_TIKTOK_ENABLED=1
# MORNING_DIGEST_TIKTOK_REGION=US
# MORNING_DIGEST_TIKTOK_MAX_VIDEOS=20
# MORNING_DIGEST_TIKTOK_PER_HASHTAG=5
# MORNING_DIGEST_TIKTOK_LOOKBACK_HOURS=24

# Instagram — Source 15 (Story 72-3)
# MORNING_DIGEST_INSTAGRAM_HASHTAGS=ai,artificialintelligence,technews
# MORNING_DIGEST_INSTAGRAM_ENABLED=1
# MORNING_DIGEST_INSTAGRAM_MAX_REELS=15
# MORNING_DIGEST_INSTAGRAM_PER_HASHTAG=5
# MORNING_DIGEST_INSTAGRAM_INCLUDE_TRENDING=1
# MORNING_DIGEST_INSTAGRAM_LOOKBACK_HOURS=168
# Note: hashtag search is Google-index-backed — sparse results expected (see task-prompt Source 15)

# Pinterest — Source 16 (Story 72-5)
# MORNING_DIGEST_PINTEREST_KEYWORDS=ai agents,claude ai,mcp servers
# MORNING_DIGEST_PINTEREST_ENABLED=1
# MORNING_DIGEST_PINTEREST_MAX_PINS=15
# MORNING_DIGEST_PINTEREST_PER_KEYWORD=5
# MORNING_DIGEST_PINTEREST_LOOKBACK_HOURS=168

# Polymarket — Source 17 (Story 72-6) — no API key
# MORNING_DIGEST_POLYMARKET_KEYWORDS=AI model,Claude,Bitcoin ETF,Fed rate cut
# MORNING_DIGEST_POLYMARKET_TAG_SLUGS=crypto,politics
# MORNING_DIGEST_POLYMARKET_ENABLED=1
# MORNING_DIGEST_POLYMARKET_MAX_MARKETS=15
# MORNING_DIGEST_POLYMARKET_MIN_VOLUME24HR=1000

# Threads — Source 18 (Story 72-7)
# MORNING_DIGEST_THREADS_HANDLES=sama,karpathy,AnthropicAI,simonw,emollick
# MORNING_DIGEST_THREADS_ENABLED=1
# MORNING_DIGEST_THREADS_MAX_POSTS=15
# MORNING_DIGEST_THREADS_PER_HANDLE=5
# MORNING_DIGEST_THREADS_LOOKBACK_HOURS=168
# Optional — only if T0 spike confirms /v1/threads/search live:
# MORNING_DIGEST_THREADS_KEYWORDS=claude ai,mcp servers
# Note: user/posts returns last 20–30 posts per handle; handles align with nexus-people.yaml / peopleMatch (68-3)

# LinkedIn — Source 19 (Story 72-8)
# MORNING_DIGEST_LINKEDIN_COMPANIES=anthropic,openai,cursor,n8n-io
# MORNING_DIGEST_LINKEDIN_PROFILES=simonw,karpathy,sama,emollick
# MORNING_DIGEST_LINKEDIN_ENABLED=1
# MORNING_DIGEST_LINKEDIN_MAX_POSTS=15
# MORNING_DIGEST_LINKEDIN_PER_TARGET=5
# MORNING_DIGEST_LINKEDIN_MAX_PAGES=1
# MORNING_DIGEST_LINKEDIN_LOOKBACK_HOURS=168
# Optional — opportunistic keyword supplement (Google-index-backed; may lag posting activity):
# MORNING_DIGEST_LINKEDIN_KEYWORDS=ai agents,mcp servers,revops automation
# Note: COMPANIES + PROFILES are dual primary watchlists (do not mix entry types). Keyword search is secondary. Profile endpoint does not return work history/job title.

# Analytics soak JSONL (Story 45-7) — optional override for audit-trend-analytics-soak.py
# Default: ~/.hermes/logs/trend-analytics.log (same path Convex runAnalyticsPass uses when unset)
# Set here for local tooling, or in Convex dashboard env for deployed Node actions.
# TREND_ANALYTICS_LOG="$HOME/.hermes/logs/trend-analytics.log"
