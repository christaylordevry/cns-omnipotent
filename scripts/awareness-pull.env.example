# Hermes awareness pull cron environment (copy to ~/.hermes/awareness-pull.env, chmod 600)
#
# Required:
CONVEX_URL="https://<deployment>.convex.cloud"
HERMES_CONVEX_READ_KEY=""

# Optional overrides:
# HERMES_AWARENESS_CACHE_PATH="~/.hermes/memories/awareness-snapshot.json"
# HERMES_AWARENESS_URL="https://<deployment>.convex.site/hermes/awareness"
